# Shared
PROJECT_NAME=portfolio-ai-stylist
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_PORT=3000

# PostgreSQL
POSTGRES_DB=portfolio_db
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=portfolio_password

# Backend
# Internal Docker service URLs. These services are not published to the host by default.
DATABASE_URL=postgresql+asyncpg://portfolio_user:portfolio_password@postgres:5432/portfolio_db
SYNC_DATABASE_URL=postgresql+psycopg://portfolio_user:portfolio_password@postgres:5432/portfolio_db
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200
INITIAL_ADMIN_EMAIL=admin@portfolio.dev
INITIAL_ADMIN_PASSWORD=admin12345
MEDIA_ROOT=/app/media
MEDIA_URL=/media
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

COMFYUI_CLIENT_ID=portfolio-local-client
COMFYUI_DIFFUSION_MODEL_NAME=flux1-krea-dev_fp8_scaled.safetensors
COMFYUI_TEXT_ENCODER_T5_NAME=t5xxl_fp8_e4m3fn.safetensors
COMFYUI_TEXT_ENCODER_CLIP_L_NAME=clip_l.safetensors
COMFYUI_VAE_NAME=ae.safetensors
COMFYUI_WORKFLOW_TEMPLATE=app/integrations/workflows/fashion_flatlay.json
CHAT_MESSAGE_COOLDOWN_SECONDS=60
GENERATION_JOB_TIMEOUT_SECONDS=300
GENERATION_QUEUE_REFRESH_COOLDOWN_SECONDS=60
GENERATION_DISPATCH_LOCK_TIMEOUT_SECONDS=30
COMFYUI_STALLED_JOB_SECONDS=180
COMFYUI_STALLED_JOB_AUTO_INTERRUPT=true
GENERATION_JOB_POLL_INTERVAL_SECONDS=10
ENABLE_GENERATION_JOB_POLLER=true
CHAT_RETENTION_DAYS=10
CHAT_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
ENABLE_CHAT_RETENTION_CLEANUP=true
ENABLE_SEARCH_INDEXING=true
VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct
VLLM_API_KEY=
VLLM_TIMEOUT_SECONDS=300
VLLM_TEMPERATURE=0.2
VLLM_MAX_TOKENS=420
VLLM_MAX_MODEL_LEN=4096

# OpenAI / ChatGPT style enrichment
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
INTERNAL_API_URL=http://backend:8000/api/v1
NEXT_PUBLIC_MEDIA_URL=http://localhost:8000/media
NEXT_PUBLIC_SITE_URL=http://localhost:3000
VLLM_BASE_URL=http://192.168.50.141:8001/v1
COMFYUI_BASE_URL=http://192.168.50.141:8188
COMFYUI_OUTPUT_ROOT=
